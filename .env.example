# Copy to .env for local dev. Loaded by the app config layer (pydantic-settings style).

# Ledger Postgres (app state: events, projections, idempotency)
LEDGER_DATABASE_URL=postgresql://ledger:ledger@localhost:5432/ledger

# Temporal
LEDGER_TEMPORAL_ADDRESS=localhost:7233
LEDGER_TEMPORAL_NAMESPACE=default
LEDGER_TEMPORAL_TASK_QUEUE=ledger-transfers

# API
LEDGER_API_HOST=0.0.0.0
LEDGER_API_PORT=8000
LEDGER_API_KEY=dev-local-key

# Observability
LEDGER_OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4317
LEDGER_SERVICE_NAME=ledger-core
LEDGER_LOG_LEVEL=INFO
